print("true + true = ", true + true, "\n");
print("true + 10 = ", true + 10, "\n");
print("true + 2.5 = ", true + 2.5, "\n");

print("5 / 2 = ", 5 / 2, "\n");
print("5 / 2.0 = ", 5 / 2.0, "\n");

print("true == 1: ", true == 1, "\n");
print("false == 0.0: ", false == 0.0, "\n");
print("1 == 1.0: ", 1 == 1.0, "\n");

print("string: ", "value = " + 10, "\n");
print("reverse: ", true + " result", "\n");

print("repeat: ", "ab" * 3, "\n");
print("reverse repeat: ", 2 * "cd", "\n");

var value = true;
value += true;

print("value = ", value, "\n");

var number = 10;
number += 2.5;

print("number = ", number, "\n");